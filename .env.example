# ------------------------------------------------------------------
# NuraSkin — Environment Variables (example)
# Copy to .env and fill in real values. Never commit .env.
# ------------------------------------------------------------------

NODE_ENV=development

# --- Database (local docker) ---
DATABASE_URL=postgres://nura:nura@localhost:5432/nura_dev

# --- Redis (local docker) ---
REDIS_URL=redis://localhost:6379

# --- Server ---
SERVER_PORT=4000
SERVER_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- JWT ---
JWT_ACCESS_SECRET=change-me-access-32-chars-min-xxxxx
JWT_REFRESH_SECRET=change-me-refresh-32-chars-min-xxxx
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_CHANNEL_ID=
TELEGRAM_WEBHOOK_URL=

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=nura_unsigned

# --- Admin web app ---
VITE_API_BASE_URL=http://localhost:4000

# --- Storefront ---
PUBLIC_API_BASE_URL=http://localhost:4000
PUBLIC_SITE_URL=http://localhost:3000

# --- Sentry (optional) ---
SENTRY_DSN_SERVER=
SENTRY_DSN_ADMIN=
SENTRY_DSN_STOREFRONT=

,
