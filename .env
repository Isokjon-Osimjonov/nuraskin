# ------------------------------------------------------------------
# NuraSkin — Environment Variables (example)
# Copy to .env and fill in real values. Never commit .env.
# ------------------------------------------------------------------

NODE_ENV=development

# --- Database (local docker) ---
DATABASE_URL=postgres://nura:nura@localhost:5432/nura_dev

# --- Redis (local docker) ---
REDIS_URL=redis://localhost:6379

# --- Server ---
SERVER_PORT=4000
SERVER_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- JWT ---
JWT_SECRET=change-me-access-32-chars-min-xxxxx
JWT_ACCESS_SECRET=change-me-access-32-chars-min-xxxxx
JWT_REFRESH_SECRET=change-me-refresh-32-chars-min-xxxx
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- Telegram ---
TELEGRAM_BOT_TOKEN=8668096345:AAEeo2uUNAy4xR7vw93FQz2S7GJL8UbBd5s
TELEGRAM_BOT_USERNAME=nuraskin_manager_bot
